{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Azure": {
    "Storage": {
      "Blob": {
        "ServiceUri": "https://notesappstore.blob.core.windows.net/",
        "ContainerName": "user-assets"
      }
    }
  },
  "AssetStorage": {
    "ContainerName": "user-assets",
    "DownloadUrlValidityMinutes": 60,
    "MaxFileSizeBytes": 52428800
  },
  "RecurringTask": {
    "HorizonWeeksAhead": 8,
    "InitialMaterializationBatchSize": 26
  },
  "AttachmentStorage": {
    "ContainerName": "user-attachments",
    "DownloadUrlValidityMinutes": 60,
    "MaxFileSizeBytes": 52428800,
    "MaxAttachmentsPerTask": 5,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/gif",
      "image/webp",
      "application/pdf"
    ]
  }
}
