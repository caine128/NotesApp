{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "OutboxWorker": {
    "MaxBatchSize": 50,
    "PollingIntervalMilliseconds": 5000,
    "MaxRetryAttempts": 10
  },
  "Azure": {
    "Storage": {
      "Blob": {
        "ServiceUri": "https://notesappstore.blob.core.windows.net/",
        "ContainerName": "user-assets"
      }
    }
  },
  "AttachmentStorage": {
    "ContainerName": "user-attachments",
    "DownloadUrlValidityMinutes": 60,
    "MaxFileSizeBytes": 52428800,
    "MaxAttachmentsPerTask": 5,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/gif",
      "image/webp",
      "application/pdf"
    ]
  }
}
